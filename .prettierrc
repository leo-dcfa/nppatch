{
    "trailingComma": "es5",
    "tabWidth": 4,
    "singleQuote": false,
    "printWidth": 120,
    "apexInsertFinalNewline": true,
    "plugins": ["prettier-plugin-apex"],
    "overrides": [
        {
            "files": "*.apex",
            "options": {
                "parser": "apex"
            }
        },
        {
            "files": "*.cls",
            "options": {
                "parser": "apex"
            }
        }
    ]
}
